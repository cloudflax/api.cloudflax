# Application
APP_ENV=development
PORT=3000
LOG_LEVEL=info
APP_URL=http://localhost:3000
JWT_SECRET=

# Database — SSL
DB_SSL_MODE=verify-full
DB_SSL_ROOT_CERT=/certs/global-bundle.pem

# AWS — use AWS_PROFILE for named profiles (~/.aws/config),
# or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY for explicit credentials.
AWS_REGION=us-east-2
AWS_SECRET_NAME=
AWS_PROFILE=dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# SES (email)
SES_FROM_ADDRESS=
