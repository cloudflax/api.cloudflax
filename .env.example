# Application
APP_ENV=development
PORT=3000
LOG_LEVEL=info
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
JWT_SECRET=68ec8aa701a5e3f2029afc4ff2dfc4ba2e433b58166c9b4c73183752afdedb7b

# Database — SSL
DB_SSL_MODE=verify-full
DB_SSL_ROOT_CERT=/certs/global-bundle.pem
# Database slow-query log threshold (milliseconds). If unset: 500 when APP_ENV=development, else 200.
DB_SLOW_QUERY_THRESHOLD_MS=1000

# AWS — use AWS_PROFILE for named profiles (~/.aws/config),
# or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY for explicit credentials.
AWS_REGION=us-east-2
AWS_SECRET_NAME=cloudflax-dev-db-secret
AWS_PROFILE=dev
# AWS_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Secrets cache
SECRETS_CACHE_TTL_SECONDS=300

# Verification email — async Lambda (payload: email, name, link). Same AWS_REGION / credentials as the rest of the app.
LAMBDA_SEND_VERIFY_EMAIL_NAME=cloudflax-dev-send-verify-email

# SES (email)
SES_FROM_ADDRESS=noreply@dev.cloudflax.com
SES_ENDPOINT_URL=
